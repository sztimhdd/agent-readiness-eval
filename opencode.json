{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "external_directory": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "git push *": "deny",
      "git reset --hard*": "deny",
      "git clean *": "deny",
      "git rebase *": "deny"
    }
  }
}
